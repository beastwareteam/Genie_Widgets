{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tabs Configuration",
  "type": "object",
  "properties": {
    "tab_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "title_key": {"type": "string"},
          "dock_area": {"type": "string"},
          "orientation": {"type": "string", "enum": ["horizontal", "vertical"]},
          "tabs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {"type": "string"},
                "title_key": {"type": "string"},
                "component": {"type": "string"},
                "closable": {"type": "boolean"},
                "active": {"type": "boolean"},
                "children": {"type": "array"}
              },
              "required": ["id"]
            }
          }
        },
        "required": ["id", "tabs"]
      }
    }
  }
}
