{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Panels Configuration",
  "type": "object",
  "properties": {
    "panels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name_key": {
            "type": "string",
            "description": "i18n key for panel name"
          },
          "area": {
            "type": "string",
            "enum": ["left", "right", "bottom", "center"]
          },
          "closable": {
            "type": "boolean"
          },
          "movable": {
            "type": "boolean"
          },
          "floatable": {
            "type": "boolean"
          },
          "delete_on_close": {
            "type": "boolean"
          },
          "dnd_enabled": {
            "type": "boolean"
          },
          "responsive_hidden_at": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "required": ["id", "area"]
      }
    }
  },
  "required": ["panels"]
}
