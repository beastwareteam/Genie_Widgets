{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Themes Configuration",
  "type": "object",
  "properties": {
    "default_theme_id": {
      "type": "string"
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "file": {
            "type": "string"
          }
        },
        "required": ["id", "name", "file"]
      }
    }
  },
  "required": ["themes"]
}
