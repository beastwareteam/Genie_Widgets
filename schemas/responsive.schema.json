{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Responsive Configuration",
  "type": "object",
  "properties": {
    "breakpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "min_width": {"type": "integer"},
          "max_width": {"type": "integer"},
          "name": {"type": "string"}
        },
        "required": ["id"]
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "panel_id": {"type": "string"},
          "breakpoint": {"type": "string"},
          "action": {"type": "string", "enum": ["hide", "show", "collapse"]}
        }
      }
    }
  }
}
