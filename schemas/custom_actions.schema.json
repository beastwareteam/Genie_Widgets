{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["custom_actions"],
  "properties": {
    "custom_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "label", "message"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
