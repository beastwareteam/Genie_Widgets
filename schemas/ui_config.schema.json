{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ui_config.schema.json",
  "title": "UI Configuration Schema",
  "description": "Schema for ui_config.json containing general UI settings",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Configuration version"
    },
    "window": {
      "type": "object",
      "description": "Main window settings",
      "properties": {
        "title": {
          "type": "string",
          "description": "Window title"
        },
        "default_width": {
          "type": "integer",
          "minimum": 100,
          "description": "Default window width"
        },
        "default_height": {
          "type": "integer",
          "minimum": 100,
          "description": "Default window height"
        },
        "min_width": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum window width"
        },
        "min_height": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum window height"
        },
        "remember_position": {
          "type": "boolean",
          "default": true,
          "description": "Remember window position"
        },
        "remember_size": {
          "type": "boolean",
          "default": true,
          "description": "Remember window size"
        },
        "start_maximized": {
          "type": "boolean",
          "default": false,
          "description": "Start maximized"
        },
        "frameless": {
          "type": "boolean",
          "default": false,
          "description": "Use frameless window"
        }
      }
    },
    "appearance": {
      "type": "object",
      "description": "Visual appearance settings",
      "properties": {
        "default_theme": {
          "type": "string",
          "description": "Default theme name"
        },
        "animations_enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable UI animations"
        },
        "animation_duration": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000,
          "default": 200,
          "description": "Animation duration in ms"
        },
        "font_family": {
          "type": "string",
          "description": "Default font family"
        },
        "font_size": {
          "type": "integer",
          "minimum": 6,
          "maximum": 72,
          "default": 10,
          "description": "Default font size"
        },
        "icon_theme": {
          "type": "string",
          "description": "Icon theme name"
        }
      }
    },
    "editor": {
      "type": "object",
      "description": "Editor settings",
      "properties": {
        "font_family": {
          "type": "string",
          "description": "Editor font family"
        },
        "font_size": {
          "type": "integer",
          "minimum": 6,
          "maximum": 72,
          "default": 12,
          "description": "Editor font size"
        },
        "tab_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8,
          "default": 4,
          "description": "Tab width in spaces"
        },
        "use_spaces": {
          "type": "boolean",
          "default": true,
          "description": "Use spaces instead of tabs"
        },
        "word_wrap": {
          "type": "boolean",
          "default": false,
          "description": "Enable word wrap"
        },
        "line_numbers": {
          "type": "boolean",
          "default": true,
          "description": "Show line numbers"
        },
        "highlight_current_line": {
          "type": "boolean",
          "default": true,
          "description": "Highlight current line"
        }
      }
    },
    "behavior": {
      "type": "object",
      "description": "Behavior settings",
      "properties": {
        "auto_save": {
          "type": "boolean",
          "default": true,
          "description": "Enable auto-save"
        },
        "auto_save_interval": {
          "type": "integer",
          "minimum": 1000,
          "default": 60000,
          "description": "Auto-save interval in ms"
        },
        "confirm_exit": {
          "type": "boolean",
          "default": true,
          "description": "Confirm before exit"
        },
        "restore_session": {
          "type": "boolean",
          "default": true,
          "description": "Restore previous session"
        }
      }
    }
  },
  "additionalProperties": true
}
