{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Menus Configuration",
  "type": "object",
  "properties": {
    "menus": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label_key": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["menu", "action", "separator"]
          },
          "action": {
            "type": "string"
          },
          "shortcut": {
            "type": "string"
          },
          "visible": {
            "type": "boolean"
          },
          "children": {
            "type": "array"
          }
        },
        "required": ["id"]
      }
    }
  },
  "required": ["menus"]
}
