      "icon": "menu",
      "order": 1,
      "widgets": [
        {
          "id": "menu_editor",
          "type": "custom",
          "label_key": "config.menu_editor.label",
          "dnd_enabled": true,
          "movable": true,
          "resizable": true,
          "container": true,
          "properties": {
            "menu_name": {
              "type": "text",
              "label_key": "config.menu_name",
              "required": true,
              "placeholder": "Enter menu name"
            },
            "menu_items": {
              "type": "multiline",
              "label_key": "config.menu_items",
              "required": false,
              "placeholder": "Add menu items"
            },
            "position": {
              "type": "select",
              "label_key": "config.menu_position",
              "default": "top",
              "options": [
                {"value": "top", "label": "config.menu.position.top"},
                {"value": "left", "label": "config.menu.position.left"},
                {"value": "right", "label": "config.menu.position.right"},
                {"value": "bottom", "label": "config.menu.position.bottom"}
              ]
            }
          }
        }
      ]
    },
