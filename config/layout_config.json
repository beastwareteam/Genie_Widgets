{
  "titlebar": {
    "collapsed_height": 3,
    "collapsed_hit_height": 6,
    "expanded_height": 36,
    "animation_duration_ms": 160
  },
  "toolbar": {
    "margin": 0,
    "padding": 0,
    "spacing": 2,
    "button_size": 24
  },
  "tabs": {
    "padding_vertical": 2,
    "padding_horizontal": 4,
